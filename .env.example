# Test Environment Configuration
TEST_ENVIRONMENT=staging

# API Configuration
YUNO_API_BASE_URL=https://api-staging.yuno.com
YUNO_API_KEY=test_key_placeholder
YUNO_API_SECRET=test_secret_placeholder

# Currency Service Configuration
FX_RATE_SERVICE_URL=https://fx-rates-staging.yuno.com
FX_RATE_CACHE_TTL=300

# Test Data Configuration
DEFAULT_TEST_MERCHANT_ID=merchant_test_001
DEFAULT_TEST_ACCOUNT_ID=account_test_001

# Webhook Configuration
WEBHOOK_ENDPOINT=https://webhook.site/test-endpoint

# Test Execution Settings
ENABLE_EXTERNAL_API_CALLS=false
USE_MOCK_FX_RATES=true
TEST_DATA_SEED=42

# Parallel Execution
MAX_PARALLEL_TESTS=4

# Reporting
GENERATE_ALLURE_REPORTS=true
SEND_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=
